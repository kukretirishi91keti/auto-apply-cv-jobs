# Anthropic API Key (for CV matching & cover letter generation)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Portal Credentials
NAUKRI_EMAIL=your@email.com
NAUKRI_PASSWORD=your_password

INDEED_EMAIL=your@email.com
INDEED_PASSWORD=your_password

FOUNDIT_EMAIL=your@email.com
FOUNDIT_PASSWORD=your_password

ZIPRECRUITER_EMAIL=your@email.com
ZIPRECRUITER_PASSWORD=your_password

LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=your_password

GLASSDOOR_EMAIL=your@email.com
GLASSDOOR_PASSWORD=your_password

# Job Aggregator APIs (free tiers — highly recommended for Streamlit Cloud)
# JSearch: https://rapidapi.com/letscrape-6bRBa3QguO5/api/jsearch — covers LinkedIn, Indeed, Glassdoor, ZipRecruiter
RAPIDAPI_KEY=your_rapidapi_key
# Adzuna: https://developer.adzuna.com/ — covers India job market
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key

# Notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
NOTIFICATION_EMAIL=your@email.com

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz
